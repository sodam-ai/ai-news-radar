# ═══════════════════════════════════════════════════════
# AI News Radar — 환경 변수 설정
# ═══════════════════════════════════════════════════════
# 이 파일을 복사하여 .env로 저장한 후, 사용할 플랫폼의 API 키를 입력하세요.
# 최소 1개의 API 키만 있으면 됩니다. (35개 플랫폼 지원)
# ═══════════════════════════════════════════════════════

# ── LLM 프로바이더 선택 (선택사항) ──
# 미설정 시 API 키가 있는 첫 번째 프로바이더를 자동으로 사용합니다.
# 명시적으로 지정하려면 아래 주석을 해제하세요.
# LLM_PROVIDER=gemini

# ══════════════════════════════════════════════════
# 무료 할당량 충분 (추천)
# ══════════════════════════════════════════════════

# Google Gemini (기본 추천) — Flash-Lite 1000회/일, Flash 250회/일
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq — 분당 30회, 일 14,400회 무료 (초고속)
# 발급: https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key_here

# Cerebras — 분당 30회 무료 (초고속 추론)
# 발급: https://cloud.cerebras.ai/
# CEREBRAS_API_KEY=your_cerebras_api_key_here

# SambaNova — 분당 10회 무료
# 발급: https://cloud.sambanova.ai/
# SAMBANOVA_API_KEY=your_sambanova_api_key_here

# xAI (Grok) — 매월 $25 무료 크레딧
# 발급: https://console.x.ai/
# XAI_API_KEY=your_xai_api_key_here

# Mistral AI — 실험용 무료 API
# 발급: https://console.mistral.ai/api-keys
# MISTRAL_API_KEY=your_mistral_api_key_here

# Cohere — 월 1,000회 무료
# 발급: https://dashboard.cohere.com/api-keys
# COHERE_API_KEY=your_cohere_api_key_here

# HuggingFace — 무료 Inference API (속도 제한)
# 발급: https://huggingface.co/settings/tokens
# HF_API_KEY=your_hf_api_key_here

# NVIDIA NIM — 가입 시 1,000 크레딧 무료
# 발급: https://build.nvidia.com/
# NVIDIA_API_KEY=your_nvidia_api_key_here

# Cloudflare Workers AI — 일 10,000 뉴런 무료
# 발급: https://dash.cloudflare.com/ → AI → Workers AI
# CF_API_TOKEN=your_cf_api_token_here
# CF_ACCOUNT_ID=your_cf_account_id_here

# Zhipu AI (GLM) — Flash 모델 무료 (중국)
# 발급: https://open.bigmodel.cn/
# ZHIPU_API_KEY=your_zhipu_api_key_here

# Kluster AI — 무료 티어
# 발급: https://kluster.ai/
# KLUSTER_API_KEY=your_kluster_api_key_here

# GLHF.chat — 무료 (커뮤니티)
# 발급: https://glhf.chat/
# GLHF_API_KEY=your_glhf_api_key_here

# Hyperbolic — 무료 티어
# 발급: https://app.hyperbolic.xyz/
# HYPERBOLIC_API_KEY=your_hyperbolic_api_key_here

# ══════════════════════════════════════════════════
# 가입 크레딧 / 저렴
# ══════════════════════════════════════════════════

# Together AI — 가입 시 $5 크레딧
# 발급: https://api.together.xyz/settings/api-keys
# TOGETHER_API_KEY=your_together_api_key_here

# OpenRouter — 일부 모델 무료 (통합 게이트웨이)
# 발급: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Fireworks AI — 가입 시 $1 크레딧
# 발급: https://fireworks.ai/account/api-keys
# FIREWORKS_API_KEY=your_fireworks_api_key_here

# DeepSeek — 매우 저렴 (100만 토큰당 $0.27)
# 발급: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepInfra — 가입 시 무료 크레딧
# 발급: https://deepinfra.com/dash/api_keys
# DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# Perplexity AI — 가입 시 $5 크레딧 (온라인 검색 포함)
# 발급: https://www.perplexity.ai/settings/api
# PERPLEXITY_API_KEY=your_perplexity_api_key_here

# AI21 Labs (Jamba) — 가입 시 무료 크레딧
# 발급: https://studio.ai21.com/account/api-key
# AI21_API_KEY=your_ai21_api_key_here

# Upstage (Solar) — 가입 시 무료 크레딧 (한국 기업)
# 발급: https://console.upstage.ai/
# UPSTAGE_API_KEY=your_upstage_api_key_here

# Lepton AI — 가입 시 무료 크레딧
# 발급: https://dashboard.lepton.ai/
# LEPTON_API_KEY=your_lepton_api_key_here

# Novita AI — 가입 시 $0.5 크레딧
# 발급: https://novita.ai/dashboard
# NOVITA_API_KEY=your_novita_api_key_here

# Nebius AI — 가입 시 무료 크레딧
# 발급: https://studio.nebius.ai/
# NEBIUS_API_KEY=your_nebius_api_key_here

# Chutes AI — 가입 시 무료 크레딧
# 발급: https://chutes.ai/
# CHUTES_API_KEY=your_chutes_api_key_here

# Replicate — 가입 시 무료 크레딧
# 발급: https://replicate.com/account/api-tokens
# REPLICATE_API_KEY=your_replicate_api_key_here

# ══════════════════════════════════════════════════
# 아시아 플랫폼
# ══════════════════════════════════════════════════

# Alibaba Qwen (DashScope) — 가입 시 100만 토큰 무료 (중국)
# 발급: https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Moonshot AI (Kimi) — 가입 시 무료 크레딧 (중국)
# 발급: https://platform.moonshot.cn/
# MOONSHOT_API_KEY=your_moonshot_api_key_here

# 01.AI (Yi) — 가입 시 무료 크레딧 (중국)
# 발급: https://platform.lingyiwanwu.com/
# YI_API_KEY=your_yi_api_key_here

# Baichuan AI — 가입 시 무료 크레딧 (중국)
# 발급: https://platform.baichuan-ai.com/
# BAICHUAN_API_KEY=your_baichuan_api_key_here

# ══════════════════════════════════════════════════
# 유료 / 엔터프라이즈 (강력)
# ══════════════════════════════════════════════════

# OpenAI — GPT-4o-mini/GPT-4o (신규 가입 시 $5 크레딧)
# 발급: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# Azure OpenAI — Azure 무료 계정 시 $200 크레딧
# 발급: https://portal.azure.com/ → Azure OpenAI
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Anthropic Claude — Claude Sonnet (유료)
# 발급: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Reka AI — 가입 시 무료 크레딧
# 발급: https://platform.reka.ai/
# REKA_API_KEY=your_reka_api_key_here

# ══════════════════════════════════════════════════
# 기타 설정
# ══════════════════════════════════════════════════

# 크롤링 주기 (분)
CRAWL_INTERVAL_MINUTES=60

# ══════════════════════════════════════════════════
# 텔레그램 봇 (선택사항)
# ══════════════════════════════════════════════════
# @BotFather에서 봇 생성 후 토큰 발급
# https://t.me/BotFather → /newbot → 토큰 복사
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_CHANNEL_ID=@your_channel_or_chat_id

# ══════════════════════════════════════════════════
# SNS 카드 뉴스 자동 업로드 (선택사항)
# ══════════════════════════════════════════════════

# X (Twitter) — https://developer.x.com/
# X_API_KEY=your_api_key
# X_API_SECRET=your_api_secret
# X_ACCESS_TOKEN=your_access_token
# X_ACCESS_SECRET=your_access_secret

# Discord Webhook — 서버설정 → 연동 → 웹훅 → URL 복사
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Threads — https://developers.facebook.com/ → 앱 → Threads API
# THREADS_ACCESS_TOKEN=your_threads_access_token
# THREADS_USER_ID=your_threads_user_id

# Instagram — https://developers.facebook.com/ → 앱 → Instagram Graph API
# (Facebook 페이지 + Instagram 비즈니스 계정 필요)
# INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
# INSTAGRAM_ACCOUNT_ID=your_instagram_account_id
# IMGUR_CLIENT_ID=your_imgur_client_id (Instagram 이미지 호스팅용)

# ══════════════════════════════════════════════════
# 뉴스레터 이메일 발송 (선택사항)
# ══════════════════════════════════════════════════
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
# NEWSLETTER_RECIPIENTS=friend1@email.com,friend2@email.com
# NEWSLETTER_SENDER_NAME=AI News Radar
